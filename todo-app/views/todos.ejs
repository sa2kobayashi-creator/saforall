<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ToDo App</title>
    <style>
      body {
        font-family: "Segoe UI", sans-serif;
        max-width: 560px;
        margin: 40px auto;
        padding: 0 16px;
        background: #f6f7f9;
        color: #222;
      }
      h1 { margin-bottom: 8px; }
      .hint { color: #666; font-size: 14px; margin-bottom: 20px; }
      form.add {
        display: flex;
        gap: 8px;
        margin-bottom: 20px;
      }
      input[type="text"] {
        flex: 1;
        padding: 10px;
        border: 1px solid #ccc;
        border-radius: 8px;
      }
      button {
        border: none;
        border-radius: 8px;
        padding: 10px 14px;
        background: #0e639c;
        color: white;
        cursor: pointer;
      }
      ul { list-style: none; padding: 0; margin: 0; }
      li {
        display: flex;
        align-items: center;
        gap: 10px;
        background: white;
        border: 1px solid #e2e5ea;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 8px;
      }
      li.done span { text-decoration: line-through; color: #888; }
      li form { margin: 0; }
      .actions { margin-left: auto; display: flex; gap: 6px; }
      .actions button { background: #555; padding: 6px 10px; font-size: 12px; }
      .actions .danger { background: #b42318; }
    </style>
  </head>
  <body>
    <h1>ToDo</h1>
    <p class="hint">表示 URL: http://localhost:3000 （example.com ではありません）</p>

    <form class="add" method="post" action="/todos">
      <input type="text" name="title" placeholder="新しい ToDo" required />
      <button type="submit">追加</button>
    </form>

    <ul>
      <% todos.forEach(function (todo) { %>
        <li class="<%= todo.completed ? 'done' : '' %>">
          <span><%= todo.title %></span>
          <div class="actions">
            <form method="post" action="/todos/<%= todo.id %>/toggle">
              <button type="submit"><%= todo.completed ? '戻す' : '完了' %></button>
            </form>
            <form method="post" action="/todos/<%= todo.id %>/delete">
              <button class="danger" type="submit">削除</button>
            </form>
          </div>
        </li>
      <% }) %>
    </ul>
  </body>
</html>
